# Host-local development example.
# Copy to .env when running Python directly on your machine.

DATABASE_URL=postgresql://loom:postgres@127.0.0.1:5432/loom_db
BASE_URL=http://127.0.0.1:8000

# Use mock for deterministic local demos; set groq when testing a real provider.
LLM_PROVIDER=mock
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

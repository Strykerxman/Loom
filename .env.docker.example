# Docker Compose development example.
# Copy to .env.docker when running API, worker, and DB through Compose.

POSTGRES_USER=loom
POSTGRES_PASSWORD=postgres
POSTGRES_DB=loom_db

DATABASE_URL=postgresql://loom:postgres@db:5432/loom_db
BASE_URL=http://api:8000

# Use mock for deterministic local demos; set groq when testing a real provider.
LLM_PROVIDER=mock
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
